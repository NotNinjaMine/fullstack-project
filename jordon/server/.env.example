# --- Server ---
APP_PORT=3001
CLIENT_URL=http://localhost:3000
APP_SECRET=replace_me_with_a_long_random_string
TOKEN_EXPIRES_IN=8h

# --- Database ---
# Dialect defaults to sqlite (zero-infra, runs anywhere). Switch to the team's
# MySQL by setting DB_DIALECT=mysql and filling in the connection details below
# — the Sequelize models are dialect-agnostic, so nothing else changes.
DB_DIALECT=sqlite
DB_STORAGE=./data/lms.sqlite

# Used only when DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PWD=
DB_NAME=leave

# --- Email (optional) ---
# Leave blank for demo mode: reset/invite links are logged to the console and
# returned in the API response so the flow works fully offline.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
