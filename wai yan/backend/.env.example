PORT=3001
NODE_ENV=development

# sqlite | pglite | pg
DB_DRIVER=sqlite
SQLITE_PATH=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=hr_leave
DB_USER=postgres
DB_PASSWORD=postgres

# Use a long random string in production (min 16+ chars)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=8h

FRONTEND_URL=http://localhost:5173
# TRUST_PROXY=true
# JSON_BODY_LIMIT=100kb
# LOGIN_RATE_MAX=30
# LOGIN_RATE_WINDOW_MS=900000
# API_RATE_MAX=300
# API_RATE_WINDOW_MS=60000

# ---------- Email (UC-12) ----------
# SMTP_MODE: console | ethereal | smtp | godaddy | off
#   console  = log only
#   ethereal = free test inbox
#   godaddy  = Professional Email on your domain (smtpout.secureserver.net)
#   smtp     = any custom SMTP
SMTP_MODE=godaddy
EMAIL_ENABLED=true

# --- GoDaddy Professional Email (domain from GoDaddy) ---
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-mailbox-password
SMTP_FROM="HR Leave System <noreply@yourdomain.com>"
EMAIL_TEST_TO=you@yourdomain.com
# If TLS errors on some networks only:
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# Alternate port if 465 blocked:
# SMTP_PORT=587
# SMTP_SECURE=false

# Gmail alternative:
# SMTP_MODE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# ---------- AI-3 Assistant (OpenRouter / OpenAI) ----------
AI_ASSISTANT_ENABLED=true
# OpenRouter (recommended if you have an OpenRouter key):
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
# Aliases also supported:
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=HR Leave Manager

# ---------- WhatsApp ----------
# WHATSAPP_PROVIDER: console | twilio | meta
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=console

# Twilio WhatsApp
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API
# WHATSAPP_PROVIDER=meta
# WHATSAPP_TOKEN=EAABxxxx
# WHATSAPP_PHONE_NUMBER_ID=123456789

# ---------- Telegram (optional alternative to email/WhatsApp) ----------
# Create a bot with @BotFather, put the token here, then store each user's
# chat id in users.telegram_chat_id (see docs/NOTIFICATIONS-SETUP.md).
# If TELEGRAM_BOT_TOKEN is empty, Telegram sends are skipped safely.
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TEST_CHAT_ID=

REMINDER_ENABLED=true
REMINDER_INTERVAL_MS=3600000
