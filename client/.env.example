VITE_API_BASE_URL=http://localhost:3001

# The client ships with a mock API (src/mocks/server.js via axios-mock-adapter)
# so it runs standalone with no backend. Defaults to "on" even without a .env.
#
# Member 1's real backend now lives in ../server (Express + Sequelize). To run
# the client against it, start that server (see server/README.md) and set:
#   VITE_USE_MOCK_API=false
#   VITE_API_BASE_URL=http://localhost:3001
# Note: the real backend currently implements Member 1's endpoints (auth,
# profile, sessions, announcements, invitations, entitlements). The employee
# leave pages (/leave, /holiday) belong to other members' verticals and still
# rely on the mock until those backends are assembled — so keep the mock ON for
# the full employee experience.
VITE_USE_MOCK_API=true
